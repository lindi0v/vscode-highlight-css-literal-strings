{
  "name": "highlight-css-strings",
  "displayName": "VSCode Highlight CSS Strings",
  "description": "Highlights and provides CSS IntelliSense in template strings marked with /* css */ in TS/JS.",
  "version": "1.0.0",
  "publisher": "lindi0v",
  "license": "CC0-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/lindi0v/vscode-highlight-css-literal-strings.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "grammars": [
      {
        "scopeName": "injection.css-in-ts",
        "path": "./syntaxes/css-in-ts.tmLanguage.json",
        "injectTo": [
          "source.ts",
          "source.tsx",
          "source.js",
          "source.jsx"
        ]
      },
      {
        "scopeName": "injection.ts-interpolation-in-css-strings",
        "path": "./syntaxes/ts-interpolation-in-css-strings.tmLanguage.json",
        "injectTo": [
          "source.ts",
          "source.tsx",
          "source.js",
          "source.jsx"
        ],
        "embeddedLanguages": {
          "meta.embedded.expression.ts": "typescript"
        }
      }
    ]
  },
  "scripts": {
    "build": "tsc -p .",
    "build:test": "tsc -p tsconfig.test.json",
    "watch": "tsc -p . -w",
    "test": "npm run build:test && node ./dist-test/test/runTest.js",
    "prepare": "husky install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,cjs,mjs,ts}\"",
    "package": "npm run build && npx vsce package"
  },
  "lint-staged": {
    "**/*.{js,cjs,mjs,ts,jsx,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.109.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.6.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "mocha": "^11.7.5",
    "prettier": "^3.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "dependencies": {
    "vscode-css-languageservice": "^6.3.3",
    "vscode-languageserver-textdocument": "^1.0.11",
    "vscode-languageserver-types": "^3.17.5"
  }
}